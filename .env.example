# Kuzhambu local runtime example.
# Copy to .env for local shell usage or map these values into your deployment system.

# Server
# Use one app at a time with SERVER_PORT and SERVER_SERVLET_CONTEXT_PATH.
# Admin defaults: 20010 /api/admin
# Portal defaults: 20011 /api/portal
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=20010
SERVER_SERVLET_CONTEXT_PATH=/api/admin
JAVA_OPTS="-Xms512m -Xmx512m"

# Database
KUZHAMBU_DB_DRIVER=com.mysql.cj.jdbc.Driver
KUZHAMBU_DB_URL=jdbc:mysql://127.0.0.1:3306/kuzhambu?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false
KUZHAMBU_DB_USERNAME=kuzhambu
KUZHAMBU_DB_PASSWORD=kuzhambu

# Redis
KUZHAMBU_REDIS_URI=redis://127.0.0.1:6379/0
KUZHAMBU_REDIS_PASSWORD=kuzhambu
KUZHAMBU_REDIS_TIMEOUT=5s
KUZHAMBU_JETCACHE_REDIS_URI=redis://:kuzhambu@127.0.0.1:6379/0
KUZHAMBU_CACHE_STAT_INTERVAL_MINUTES=15

# RocketMQ
KUZHAMBU_ROCKETMQ_NAME_SERVER=127.0.0.1:9876
KUZHAMBU_ROCKETMQ_PRODUCER_GROUP=kuzhambu-admin-starter-producer

# OpenAPI
KUZHAMBU_OPENAPI_ENABLED=true

# Multipart upload, admin starter only.
KUZHAMBU_MULTIPART_MAX_FILE_SIZE=20MB
KUZHAMBU_MULTIPART_MAX_REQUEST_SIZE=20MB

# Logging
KUZHAMBU_LOG_PATH=logs
KUZHAMBU_LOG_LEVEL=INFO
KUZHAMBU_APP_LOG_LEVEL=INFO
KUZHAMBU_LOG_MAX_HISTORY=30
KUZHAMBU_LOG_MAX_FILE_SIZE=100MB
KUZHAMBU_LOG_TOTAL_SIZE_CAP=5GB

# OSS
# local or s3
KUZHAMBU_OSS_TYPE=local
KUZHAMBU_OSS_LOCAL_ROOT_PATH=storage/object
KUZHAMBU_OSS_S3_ENDPOINT=http://127.0.0.1:9000
KUZHAMBU_OSS_S3_REGION=us-east-1
KUZHAMBU_OSS_S3_BUCKET=kuzhambu-storage
KUZHAMBU_OSS_S3_ACCESS_KEY=kuzhambuminio
KUZHAMBU_OSS_S3_SECRET_KEY=
KUZHAMBU_OSS_S3_PATH_STYLE_ACCESS=true
KUZHAMBU_STORAGE_BUCKET_NAME=local
KUZHAMBU_STORAGE_CONTENT_PATH=/api/storage/object/

# Elasticsearch
KUZHAMBU_ELASTICSEARCH_URIS=http://127.0.0.1:9200
